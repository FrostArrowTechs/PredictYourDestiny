# ──────────────────────────────────────────────────────────────
#  Frontend build-time configuration
#
#  The SPA and API ship as separate images, so the SPA must know
#  where the API lives. Set VITE_API_BASE_URL to the API origin at
#  build time. Leave it empty for local dev (the Vite proxy handles
#  /api → :8080).
# ──────────────────────────────────────────────────────────────

# Example for Cloudflare Pages build command:
#   VITE_API_BASE_URL=https://api.yourdomain.com npm run build
VITE_API_BASE_URL=
