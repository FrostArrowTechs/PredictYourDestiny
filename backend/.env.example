# ──────────────────────────────────────────────────────────────
#  Bootstrap configuration (bootstrap = 引导)
#  Only the minimum needed to connect to PostgreSQL lives here.
#  Everything else (AI keys, model lists, feature flags, etc.)
#  is stored in the `settings` table and editable from the admin
#  panel at runtime — no restart, no redeploy required.
# ──────────────────────────────────────────────────────────────

# PostgreSQL DSN. Used at startup to open the GORM connection.
# Override by exporting DATABASE_URL in production.
# If dbname is omitted or set to "postgres", the server will use
# "predictdestiny" and create the database if it doesn't exist
# (requires CREATEDB privilege on the connection role).
DATABASE_URL="host=127.0.0.1 user=postgres password=postgres dbname=postgres port=5432 sslmode=disable TimeZone=Asia/Shanghai"
HISTORY_RETENTION_DAYS=365
AI_RESERVATION_RETENTION_DAYS=30

# HTTP server
SERVER_ADDR=":8080"

# Runtime environment. Production requires an explicit comma-separated CORS
# allowlist containing the public frontend and admin origins.
APP_ENV="development"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

# JWT signing secret. Must be set; auth endpoints will refuse to
# work without it. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# AES-256-GCM key used to encrypt AI provider API keys in the database.
# Generate once with: openssl rand -base64 32
# Keep it stable across deploys and store it in the platform secret manager.
AI_PROVIDER_ENCRYPTION_KEY=""

# Optional first-admin bootstrap. Both values are required when no admin exists;
# the password must contain at least 12 characters. No default is provided.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Optional: change bootstrap log level (debug|info|warn|error)
LOG_LEVEL="info"
